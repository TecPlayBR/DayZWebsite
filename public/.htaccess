# ============================================================
# Tecplay - DayZ Website Template
# ============================================================
# Rewrite tudo pra index.php (front controller pattern)
# ============================================================

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Forca HTTPS (descomente se voce tem SSL ativado no dominio)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Permite acesso direto a arquivos/pastas reais (imagens, css, js)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Tudo o resto -> index.php
    RewriteRule ^ index.php [L]
</IfModule>

# Cache de assets estaticos (1 ano - assets versionados por nome)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png  "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css   "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Compressao
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/xml application/xml application/json
</IfModule>

# Cache headers via mod_headers (fallback se ExpiresActive nao funciona)
<IfModule mod_headers.c>
    <FilesMatch "\.(jpg|jpeg|png|webp|gif|svg|woff2|woff|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
    # Seguranca: no cache pro HTML dinamico
    <FilesMatch "\.php$">
        Header set Cache-Control "no-store, no-cache, must-revalidate"
    </FilesMatch>
</IfModule>

# Seguranca: headers de protecao (defesa em profundidade).
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # HSTS: o navegador so honra sobre HTTPS (em HTTP e ignorado, entao e seguro).
    # Sem includeSubDomains/preload pra nao afetar subdominio HTTP-only do cliente.
    Header always set Strict-Transport-Security "max-age=31536000"
    # CSP em modo Report-Only (FASE 1): NAO bloqueia nada, so REPORTA violacoes pra
    # /api/csp-report.php. Inline permitido (site usa script/estilo inline + SDK do MP).
    # Quando os reports confirmarem que nada legitimo viola (checkout MP, avatar Steam,
    # fontes), trocar "Content-Security-Policy-Report-Only" por "Content-Security-Policy"
    # pra enforce. NAO enforce sem testar no navegador antes (quebra o checkout).
    Header always set Content-Security-Policy-Report-Only "default-src 'self'; script-src 'self' 'unsafe-inline' https://sdk.mercadopago.com https://*.mlstatic.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; frame-src https://www.mercadopago.com https://www.mercadopago.com.br https://mercadopago.com https://*.mercadolibre.com; connect-src 'self' https://api.mercadopago.com https://*.mercadolibre.com https://*.mlstatic.com; base-uri 'self'; form-action 'self' https://www.mercadopago.com https://www.mercadopago.com.br; frame-ancestors 'self'; report-uri /api/csp-report.php"
</IfModule>

# Bloqueia indexacao de diretorios
Options -Indexes

# Bloqueia acesso a arquivos sensiveis (defesa em profundidade)
<FilesMatch "\.(env|sql|md|log|json|lock)$">
    Require all denied
</FilesMatch>
