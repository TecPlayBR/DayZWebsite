# ============================================================
# Tecplay - DayZ Website Template
# ============================================================
# Rewrite tudo pra index.php (front controller pattern)
# ============================================================

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Forca HTTPS (descomente se voce tem SSL ativado no dominio)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Permite acesso direto a arquivos/pastas reais (imagens, css, js)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Tudo o resto -> index.php
    RewriteRule ^ index.php [L]
</IfModule>

# Cache de assets estaticos (1 ano - assets versionados por nome)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png  "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css   "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Compressao
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/xml application/xml application/json
</IfModule>

# Cache headers via mod_headers (fallback se ExpiresActive nao funciona)
<IfModule mod_headers.c>
    <FilesMatch "\.(jpg|jpeg|png|webp|gif|svg|woff2|woff|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
    # Seguranca: no cache pro HTML dinamico
    <FilesMatch "\.php$">
        Header set Cache-Control "no-store, no-cache, must-revalidate"
    </FilesMatch>
</IfModule>

# Seguranca: headers de protecao (defesa em profundidade).
# OBS: Content-Security-Policy NAO entra aqui ainda — o site usa scripts/estilos inline
# + SDK do Mercado Pago + Steam; CSP precisa ser testado com Content-Security-Policy-Report-Only
# antes, senao quebra o checkout. Deixado como follow-up consciente.
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # HSTS: o navegador so honra sobre HTTPS (em HTTP e ignorado, entao e seguro).
    # Sem includeSubDomains/preload pra nao afetar subdominio HTTP-only do cliente.
    Header always set Strict-Transport-Security "max-age=31536000"
</IfModule>

# Bloqueia indexacao de diretorios
Options -Indexes

# Bloqueia acesso a arquivos sensiveis (defesa em profundidade)
<FilesMatch "\.(env|sql|md|log|json|lock)$">
    Require all denied
</FilesMatch>
