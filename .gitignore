# ============================================================
# Tecplay - DayZ Website Template
# ============================================================

# Config real (cliente gera via install.php)
config/config.php

# Skin customizada do cliente (override CSS) — cada instalação tem o seu
public/assets/css/theme.override.css

# Marca customizada do cliente (logo/favicon/backgrounds enviados pelo painel)
# — NÃO é sobrescrita em update; cada instalação tem a sua.
public/assets/img/custom/*
!public/assets/img/custom/.gitkeep

# Storage runtime — só estrutura vai pro repo via .gitkeep
storage/backups/*
!storage/backups/.gitkeep
storage/cache/*
!storage/cache/.gitkeep
storage/logs/*
!storage/logs/.gitkeep
storage/ratelimit/*
!storage/ratelimit/.gitkeep
storage/server-status/*
!storage/server-status/.gitkeep

# Galeria — imagens locais de teste
public/assets/img/gallery/seed_*.png
public/assets/img/gallery/g_*.jpg
public/assets/img/gallery/g_*.png
public/assets/img/gallery/g_*.webp
public/assets/img/gallery/g_*.gif

# Builds e backups
*.zip
*.sql.gz
*.sql.bz2

# Editores / OS
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db
desktop.ini

# Logs / temporários
*.log
*.tmp
.env
.env.local

# PHP
vendor/
composer.lock
